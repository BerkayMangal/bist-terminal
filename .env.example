# BistBull Terminal — environment variable reference.
# Copy to .env and fill values. Never commit .env.

# ============ REQUIRED ============
# JWT signing secret. App refuses to start without this (see core/auth.py).
# Must be >= 32 chars. Generate via:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-random-32-chars-or-more

# ============ OPTIONAL ============
# Set to 1 when behind a trusted reverse proxy (e.g. Railway, CloudFront).
# Required for correct client IP extraction in rate limiter.
TRUST_PROXY=0

# Database path (default: /data/bistbull.db on Railway's mounted volume).
# BISTBULL_DB_PATH=/tmp/bistbull.db

# AI providers — leave empty to disable, the app degrades gracefully.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROK_API_KEY=xai-...
# PERPLEXITY_API_KEY=pplx-...

# CORS — comma-separated list of allowed origins.
# ALLOWED_ORIGINS=https://bistbull.ai,https://www.bistbull.ai
